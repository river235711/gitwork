#!/bin/bash
#==============================================================================
# pdkgui  -- launcher (bash)
#
# This script can be moved to any directory; it does not have to sit next to
# pdkgui.py. Put it on PATH (or make an alias) and just type:  pdkgui
#
# Key point: it loads a tkinter-capable python via Environment Modules
#            (default python/3.6.3, the one that already works).
#
# Order for locating the main program pdkgui.py:
#   1. pdkgui.py sitting next to this script (highest priority: a full-path run
#      always runs the app beside it, unaffected by a stray PDKGUI_HOME)
#   2. environment variable $PDKGUI_HOME   (used when the launcher is moved away)
#   3. the built-in DEFAULT_HOME below
#
# Overridable environment variables:
#   PDKGUI_HOME     directory containing pdkgui.py
#   PDKGUI_MODULE   python to module-load (default python/3.6.3)
#   PDKGUI_PYTHON   python executable to use directly (skips module-load detection)
#
# All arguments are forwarded to pdkgui.py, which runs in the background (&).
#==============================================================================

# --- Built-in default install path (used when $PDKGUI_HOME is unset and the
#     script is not next to the app) ------------------------------------------
DEFAULT_HOME="/home/willhuang/work/gitwork/python/pdkgui"

# --- 1. Resolve this script's real directory (following symlinks) ------------
SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
    _dir="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"
    SOURCE="$(readlink "$SOURCE")"
    [[ "$SOURCE" != /* ]] && SOURCE="$_dir/$SOURCE"
done
SELFDIR="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"

# --- 2. Decide which directory holds pdkgui.py -------------------------------
#   Prefer "pdkgui.py sits next to the launcher" (most intuitive: a full-path
#   run always runs the app beside it, unaffected by a stale PDKGUI_HOME);
#   otherwise use PDKGUI_HOME, then the built-in default.
if [ -f "$SELFDIR/pdkgui.py" ]; then
    HOME_DIR="$SELFDIR"
elif [ -n "$PDKGUI_HOME" ]; then
    # allow a relative path: normalise to absolute (use as-is if that fails)
    HOME_DIR="$(cd "$PDKGUI_HOME" 2>/dev/null && pwd || printf '%s' "$PDKGUI_HOME")"
else
    HOME_DIR="$DEFAULT_HOME"
fi

PDKGUI_PY="$HOME_DIR/pdkgui.py"
if [ ! -f "$PDKGUI_PY" ]; then
    echo "pdkgui: main program not found: $PDKGUI_PY" >&2
    echo "        Set PDKGUI_HOME to the directory containing pdkgui.py, e.g.:" >&2
    echo "          export PDKGUI_HOME=/path/to/pdkgui" >&2
    exit 1
fi

# --- 3. Load a tkinter-capable python (Environment Modules) ------------------
#   A non-interactive shell has no `module` function, so source its init first.
if ! type module >/dev/null 2>&1; then
    for _init in "$MODULESHOME/init/bash" \
                 /usr/share/Modules/init/bash \
                 /etc/profile.d/modules.sh \
                 /usr/share/lmod/lmod/init/bash; do
        if [ -f "$_init" ]; then
            source "$_init"
            break
        fi
    done
fi

PDKGUI_MODULE="${PDKGUI_MODULE:-python/3.6.3}"
if type module >/dev/null 2>&1; then
    module purge          >/dev/null 2>&1
    module load "$PDKGUI_MODULE" >/dev/null 2>&1
fi

# --- 4. Find a python that actually has tkinter ------------------------------
#   Candidates: $PDKGUI_PYTHON (user-specified) > python3 > python
PY=""
for _c in "$PDKGUI_PYTHON" python3 python; do
    [ -n "$_c" ] || continue
    if "$_c" -c 'import tkinter' >/dev/null 2>&1; then
        PY="$_c"
        break
    fi
done

if [ -z "$PY" ]; then
    echo "pdkgui: no python with a built-in tkinter found." >&2
    echo "        - Check the module name (currently: $PDKGUI_MODULE), or use" >&2
    echo "          export PDKGUI_MODULE=python/<version>  to pick another one" >&2
    echo "        - Or point directly at a tkinter-capable python:" >&2
    echo "          export PDKGUI_PYTHON=/path/to/python3" >&2
    echo "        - Or install it:  sudo yum install python3-tkinter" >&2
    exit 1
fi

# --- 5. Run in the background (forwarding all arguments) ---------------------
"$PY" "$PDKGUI_PY" "$@" &
echo "pdkgui started in the background (PID $!, python: $PY)"
